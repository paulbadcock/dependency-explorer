---
import { SplitPanel } from '../../components/SplitPanel'
import { analysisGet } from '../../lib/analysis'
import { analysisListRecent } from '../../lib/cache'

const { id } = Astro.params
const analysis = id ? await analysisGet(id) : null
if (!analysis) return Astro.redirect('/', 302)

const others = (await analysisListRecent(20)).filter(r => r.id !== id)
const ecosystem = analysis.filename === 'packages.lock.json' ? 'nuget' : 'pypi'
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{analysis.label ?? analysis.filename} — Dependency Explorer</title>
  </head>
  <body class="min-h-screen bg-surface text-white flex flex-col" style="height:100vh">

    <header class="flex items-center justify-between px-4 py-2 border-b border-border flex-shrink-0 relative">
      <a href="/" class="text-muted text-sm hover:text-white transition-colors">← Upload</a>
      <div class="text-center">
        <div class="font-mono text-sm">{analysis.label ?? analysis.filename}</div>
        {analysis.label && (
          <div class="text-muted text-xs">{analysis.filename}</div>
        )}
      </div>
      <div class="relative">
        {others.length > 0 ? (
          <>
            <button
              id="compare-toggle"
              class="text-xs text-muted border border-border rounded px-2 py-1 hover:text-white hover:border-muted transition-colors"
            >
              Compare ↓
            </button>
            <div
              id="compare-menu"
              class="hidden absolute right-0 top-full mt-1 w-64 bg-panel border border-border rounded-lg shadow-lg z-10 overflow-hidden"
            >
              {others.map((item, i) => (
                <a
                  href={`/compare/${id}/${item.id}`}
                  class:list={[
                    'flex items-center justify-between px-3 py-2 hover:bg-surface transition-colors text-xs',
                    i < others.length - 1 ? 'border-b border-border' : '',
                  ]}
                >
                  <span class="font-mono truncate">{item.label ?? item.filename}</span>
                  {item.totalCves > 0
                    ? <span class="text-red-text shrink-0 ml-2">{item.totalCves} CVE</span>
                    : <span class="text-green-text shrink-0 ml-2">clean</span>
                  }
                </a>
              ))}
            </div>
          </>
        ) : (
          <span class="text-xs text-muted">{new Date(analysis.createdAt).toLocaleDateString()}</span>
        )}
      </div>
    </header>

    <div class="flex flex-1 overflow-hidden">
      <SplitPanel packages={analysis.packages} ecosystem={ecosystem} client:load />
    </div>

    <script>
      const toggle = document.getElementById('compare-toggle')
      const menu = document.getElementById('compare-menu')
      toggle?.addEventListener('click', e => {
        e.stopPropagation()
        menu?.classList.toggle('hidden')
      })
      document.addEventListener('click', () => menu?.classList.add('hidden'))
    </script>
  </body>
</html>
